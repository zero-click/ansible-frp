[common]
# 绑定端口
bind_port = {{ frp_server_bind_port }}

{% if frp_server_vhost_http_port is defined %}
# 虚拟主机HTTP端口
vhost_http_port = {{ frp_server_vhost_http_port }}
{% endif %}
{% if frp_server_vhost_https_port is defined %}
vhost_https_port = {{ frp_server_vhost_https_port }}
{% endif %}

# Dashboard配置
dashboard_port = {{ frp_server_dashboard_port }}
dashboard_user = {{ frp_server_dashboard_user }}
dashboard_pwd = {{ frp_server_dashboard_password }}

# Token认证
authentication_method = token
token = {{ frp_server_token }}

# 日志配置
log_file = {{ frp_server_log_file }}
log_level = {{ frp_server_log_level }}
log_max_days = {{ frp_server_log_max_days }}

# 连接池配置
# 限制每个客户端可以创建的代理数量，防止资源耗尽
max_pool_count = {{ frp_server_max_pool_count }}
{% if frp_server_allowed_ips is defined %}

# 访问控制
allow_ports = {{ frp_server_allowed_ips | join(',') }}
{% endif %}
